# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SITE_URL=https://your-project.vercel.app

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_string

# ── File Storage (Vercel Blob) ────────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local tab
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# ── Stripe keys are stored in DB via Admin Dashboard → Payment Settings ───────
# (no Stripe keys needed in .env)
